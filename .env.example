# Optional: Upstash Redis for distributed API rate limits (proxy).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Rate limit client identity: vercel | first-hop | none (unset: vercel on Vercel, else none).
# RATE_LIMIT_TRUST_PROXY=

# Required in production: public base URL of the app.
# Consumed by shared/lib/env.ts (Zod validation), next.config.ts (Server Actions allowedOrigins),
# app/layout.tsx (metadataBase), app/sitemap.ts, app/robots.ts, Playwright baseURL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
